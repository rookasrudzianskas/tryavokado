# ---------------------------------------------------------------------------
# Avokado environment configuration (EXAMPLE)
# ---------------------------------------------------------------------------
# Copy this file to `.env.local` and fill in real values for local dev.
# NEVER commit `.env`, `.env.local`, service-account JSON, or any real secret.
# All third-party tokens are encrypted at rest with ENCRYPTION_KEY.
#
# Avokado runs fully in MOCK MODE with zero third-party credentials. Each
# integration automatically falls back to a clearly-labelled mock adapter
# when its credentials are absent. Provide real credentials only when you are
# ready to talk to the real service.
# ---------------------------------------------------------------------------

# ---- Core (required) ------------------------------------------------------
# Postgres connection string.
DATABASE_URL=postgresql://user:password@localhost:5432/avokado_dev

# Secret used to sign auth sessions. Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=
# Public base URL of the app.
NEXT_PUBLIC_APP_URL=http://localhost:3000
BETTER_AUTH_URL=http://localhost:3000

# 32-byte key (base64) used for AES-256-GCM encryption of stored third-party
# tokens. Generate with: openssl rand -base64 32
ENCRYPTION_KEY=

# Global app mode: "mock" forces every integration to its mock adapter.
# "live" uses real adapters where credentials exist and mock where they don't.
AVOKADO_MODE=mock
NEXT_PUBLIC_AVOKADO_MODE=mock

# ---- Google sign-in (OAuth login — separate from Vertex AI) ---------------
# Create an OAuth 2.0 Client (Web) in Google Cloud and add the callback:
#   {NEXT_PUBLIC_APP_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Default billing / display currency (ISO 4217). Avokado bills in EUR.
DEFAULT_CURRENCY=EUR
NEXT_PUBLIC_DEFAULT_CURRENCY=EUR

# ---- Firebase (web client config — public by design) ----------------------
# From the Firebase console → Project settings → Your apps. These are not secret.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=
# Firebase Admin (server) uses Application Default Credentials /
# GOOGLE_APPLICATION_CREDENTIALS — never paste a private key here or commit the JSON.
FIREBASE_ADMIN_PROJECT_ID=

# ---- Human help / expert handoff ------------------------------------------
# One-time price for connecting a human specialist, in EUR.
HUMAN_HELP_PRICE_EUR=500

# ---- Google Vertex AI (brand intelligence, structured generation) ---------
# Production auth uses Application Default Credentials / Workload Identity.
# For local dev you may point GOOGLE_APPLICATION_CREDENTIALS at a rotated,
# least-privilege service-account JSON that lives OUTSIDE the repo.
# NEVER commit the JSON file or paste a private key here.
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=global
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_APPLICATION_CREDENTIALS=
VERTEX_TEXT_MODEL=gemini-2.5-pro
VERTEX_FAST_MODEL=gemini-2.5-flash
VERTEX_VISION_MODEL=gemini-2.5-flash

# ---- Shopify --------------------------------------------------------------
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_SCOPES=read_products,read_orders,read_content
SHOPIFY_APP_URL=

# ---- WooCommerce ----------------------------------------------------------
# Per-store credentials are entered by the user and encrypted at rest.
# No global secret is required for WooCommerce.

# ---- Meta (Facebook / Instagram Marketing API) ----------------------------
META_APP_ID=
META_APP_SECRET=
META_GRAPH_API_VERSION=v23.0
META_CONFIG_ID=
META_MCP_ENABLED=false
META_MCP_URL=

# ---- Stripe (Avokado subscription billing) --------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_SCALE=

# ---- Object storage (Cloudflare R2 / any S3-compatible) -------------------
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=avokado-assets
R2_REGION=auto
R2_ENDPOINT=
R2_PUBLIC_URL=

# ---- Background jobs (Inngest) --------------------------------------------
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
INNGEST_DEV=true

# ---- Email (Resend) -------------------------------------------------------
RESEND_API_KEY=
EMAIL_FROM=Avokado <hello@tryavokado.com>

# ---- Monitoring & analytics ----------------------------------------------
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ENVIRONMENT=development
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
