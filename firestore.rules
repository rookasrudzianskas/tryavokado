rules_version = '2';

// Avokado Firestore security rules.
// Data is accessed from the client SDK, so these rules ARE the security boundary.
// Deploy with: firebase deploy --only firestore:rules
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isMemberOf(workspaceId) {
      return signedIn() &&
        request.auth.uid in
          get(/databases/$(database)/documents/workspaces/$(workspaceId)).data.memberUids;
    }

    // A user can only read/write their own profile document.
    match /users/{uid} {
      allow read, write: if signedIn() && request.auth.uid == uid;
    }

    match /workspaces/{workspaceId} {
      // Creator must include themselves as a member.
      allow create: if signedIn() &&
        request.auth.uid in request.resource.data.memberUids;
      allow read, update, delete: if signedIn() &&
        request.auth.uid in resource.data.memberUids;

      // All workspace subcollections (products, stores, audit, conversations…)
      // are readable/writable only by members of that workspace.
      match /{document=**} {
        allow read, write: if isMemberOf(workspaceId);
      }
    }
  }
}
